<?php

use Drupal\Core\Cache\Cache;
use Drupal\Core\Entity\EntityFormInterface;
use Drupal\gr_core\Entity\Category;
use Drupal\gr_core\Entity\Difficulty;
use Drupal\gr_core\Entity\Measurement;
use Drupal\gr_core\Entity\Season;
use Drupal\gr_core\Entity\DishType;
use Drupal\gr_core\Entity\Tag;
use Drupal\gr_core\Entity\Ingredient;
use Drupal\gr_core\Entity\File;
use Drupal\gr_core\Entity\Recipe;
use Drupal\gr_core\Entity\Meal;
use Drupal\gr_core\Entity\NutritionPlan;
use Drupal\gr_core\Entity\IngredientParagraph;
use Drupal\gr_core\Entity\StepParagraph;

function gr_core_entity_bundle_info_alter(array &$bundles): void {
  if (isset($bundles['taxonomy_term']['category'])) {
    $bundles['taxonomy_term']['category']['class'] = Category::class;
  }
  if (isset($bundles['taxonomy_term']['difficulty'])) {
    $bundles['taxonomy_term']['difficulty']['class'] = Difficulty::class;
  }
  if (isset($bundles['taxonomy_term']['season'])) {
    $bundles['taxonomy_term']['season']['class'] = Season::class;
  }
  if (isset($bundles['taxonomy_term']['dish_type'])) {
    $bundles['taxonomy_term']['dish_type']['class'] = DishType::class;
  }
  if (isset($bundles['taxonomy_term']['measurement'])) {
    $bundles['taxonomy_term']['measurement']['class'] = Measurement::class;
  }
  if (isset($bundles['taxonomy_term']['tags'])) {
    $bundles['taxonomy_term']['tags']['class'] = Tag::class;
  }
  if (isset($bundles['node']['ingredient'])) {
    $bundles['node']['ingredient']['class'] = Ingredient::class;
  }
  if (isset($bundles['node']['recipe'])) {
    $bundles['node']['recipe']['class'] = Recipe::class;
  }
  if (isset($bundles['file']['file'])) {
    $bundles['file']['file']['class'] = File::class;
  }
  if (isset($bundles['node']['meal'])) {
    $bundles['node']['meal']['class'] = Meal::class;
  }
  if (isset($bundles['node']['nutrition_plan'])) {
    $bundles['node']['nutrition_plan']['class'] = NutritionPlan::class;
  }
  if (isset($bundles['paragraph']['ingredient_paragraph'])) {
    $bundles['paragraph']['ingredient_paragraph']['class'] = IngredientParagraph::class;
  }
  if (isset($bundles['paragraph']['step_paragraph'])) {
    $bundles['paragraph']['step_paragraph']['class'] = StepParagraph::class;
  }
}